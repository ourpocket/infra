# Payment Provider Sandbox Credentials
# Copy to .env and fill in real values from provider dashboards

# Flutterwave (https://dashboard.flutterwave.com)
FLW_TEST_KEY=FLW_TEST_xxxxxxxxxxxx
FLW_TEST_SECRET=FLW_TEST_xxxxxxxxxxxx
FLW_PUBLIC_KEY=FLW_PUBLIC_xxxxxxxxxxxx
FLW_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Paystack (https://dashboard.paystack.com)
PAYSTACK_TEST_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# MTN Mobile Money (https://momodeveloper.mtn.com)
MTN_API_USER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MTN_API_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MTN_PRIMARY_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MTN_SECONDARY_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Airtel Money (https://developers.airtel.africa)
AIRTEL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRTEL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Orange Money (https://developer.orange.com)
ORANGE_MERCHANT_CODE=xxxxxxxx
ORANGE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Environment
NODE_ENV=development
