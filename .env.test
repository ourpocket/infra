# Test Environment Configuration
# Used by jest E2E tests

NODE_ENV=test

# PostgreSQL (from docker-compose.test.yml) - using port 5433 to avoid conflict with native PostgreSQL
DATABASE_URL=postgresql://ourpocket:ourpocket@localhost:5433/ourpocket

# Redis (from docker-compose.test.yml)
REDIS_URL=redis://localhost:6379

# Flutterwave Sandbox (optional - tests skip if not set)
# FLW_SECRET_KEY=FLWSECK_TEST-xxx
# FLW_PUBLIC_KEY=FLWPUBK_TEST-xxx
